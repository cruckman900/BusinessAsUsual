@page "/finance"
@page "/finance/home"
@inject IFinanceReportService ReportService
@inject NavigationManager Navigation

<PageTitle>Finance</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-2 pa-0">
    <div class="mb-3">
        <MudLink Href="/dashboard">Dashboard</MudLink>
        <span class="mx-2">/</span>
        <MudText Typo="Typo.body2" Inline="true" Color="Color.Primary">Finance</MudText>
    </div>

    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="mr-2" />
        Finance
    </MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        Manage receivables, payables, payroll, and track revenue
    </MudText>

    <!-- Main Module Cards Grid -->
    <MudGrid Spacing="3" Class="mb-6">
        <!-- Accounts Receivable -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.RequestQuote" Size="Size.Large" Color="Color.Primary" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Accounts Receivable</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Manage customer invoices and collections
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">@(_summary is not null ? _summary.TotalOutstanding.ToString("C0") : "—") Outstanding</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/finance/receivables">
                        View Receivables
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Accounts Payable -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Large" Color="Color.Warning" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Accounts Payable</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Track vendor bills and outgoing payments
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">@(_summary is not null ? _summary.OverdueCount.ToString() : "0") Overdue</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/finance/payables">
                        View Payables
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Invoices -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Large" Color="Color.Info" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Invoices</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Create and manage customer invoices
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@(_summary is not null ? _summary.TotalOverdue.ToString("C0") : "—") Overdue</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/finance/invoices">
                        View Invoices
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Payments -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Large" Color="Color.Success" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Payments</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Record and reconcile incoming payments
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">@(_summary is not null ? _summary.TotalPaidThisMonth.ToString("C0") : "—") This Month</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/finance/payments">
                        View Payments
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Payroll -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Large" Color="Color.Tertiary" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Payroll</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Run pay cycles and manage deductions
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Text">Bi-weekly</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/finance/payroll">
                        View Payroll
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Reports -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Large" Color="Color.Secondary" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Reports & Analytics</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Revenue trends and financial reporting
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text">6 Reports</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/finance/reports">
                        View Reports
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>

    <!-- Quick Stats -->
    <MudPaper Class="pa-4 mb-6" Elevation="1">
        <MudText Typo="Typo.h6" GutterBottom="true">
            <MudIcon Icon="@Icons.Material.Filled.QueryStats" Class="mr-2" />
            Quick Stats
        </MudText>
        @if (_loading)
        {
            <div class="d-flex justify-center align-center" style="min-height: 120px;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (_summary is not null)
        {
            <MudGrid Spacing="2">
                <MudItem xs="6" sm="3">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h4" Color="Color.Primary">@_summary.TotalOutstanding.ToString("C0")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Outstanding</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h4" Color="Color.Error">@_summary.TotalOverdue.ToString("C0")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Overdue</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h4" Color="Color.Success">@_summary.TotalPaidThisMonth.ToString("C0")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Paid This Month</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h4" Color="Color.Warning">@_summary.OverdueCount</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Overdue Invoices</MudText>
                    </MudStack>
                </MudItem>
            </MudGrid>
        }
    </MudPaper>

    <!-- About & Module Info Grid -->
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4 d-flex flex-column" Elevation="1" Style="height: 100%;">
                <MudText Typo="Typo.h6" GutterBottom="true">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                    About Finance Module
                </MudText>
                <MudText Typo="Typo.body2" Class="mb-4">
                    The Finance module provides comprehensive financial management capabilities including:
                </MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Accounts Receivable</strong> - Manage customer invoices and collections
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Accounts Payable</strong> - Track vendor bills and outgoing payments
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Invoicing</strong> - Create, deliver, and track customer invoices
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Payments</strong> - Record and reconcile incoming payments
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Payroll</strong> - Run pay cycles and manage deductions
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Reporting &amp; Analytics</strong> - Revenue trends and financial reporting
                    </MudListItem>
                </MudList>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-auto pt-4">
                    This module is dynamically loaded via the Module Registry Service and provides both web UI and mobile API contracts.
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 d-flex flex-column" Elevation="1" Style="height: 100%;">
                <MudText Typo="Typo.h6" GutterBottom="true">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
                    Module Info
                </MudText>
                <MudStack Spacing="2" Class="flex-grow-1">
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Module ID</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Filled">finance</MudChip>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Version</MudText>
                        <MudText Typo="Typo.body2">1.0.0</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">API Port</MudText>
                        <MudText Typo="Typo.body2">5006</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Web UI Port</MudText>
                        <MudText Typo="Typo.body2">5009</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Mobile Support</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Yes</MudChip>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Active</MudChip>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .mud-card-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15) !important;
    }
</style>

@code {
    private bool _loading = true;
    private FinanceSummaryDto? _summary;

    protected override async Task OnInitializedAsync()
    {
        _summary = await ReportService.GetSummaryAsync();
        _loading = false;
    }
}
