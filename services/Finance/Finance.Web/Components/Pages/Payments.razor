@page "/finance/payments"
@inject IPaymentService PaymentService

<PageTitle>Payments</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-2 pa-0">
    <div class="mb-3">
        <MudLink Href="/dashboard">Dashboard</MudLink>
        <span class="mx-2">/</span>
        <MudLink Href="/finance">Finance</MudLink>
        <span class="mx-2">/</span>
        <MudText Typo="Typo.body2" Inline="true" Color="Color.Primary">Payments</MudText>
    </div>

    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h4" GutterBottom="true">
                <MudIcon Icon="@Icons.Material.Filled.Payments" Class="mr-2" />
                Payments
            </MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">Record and reconcile incoming payments</MudText>
        </div>
    </div>

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <MudTable Items="@_payments" Hover="true" Elevation="2" Dense="true">
            <HeaderContent>
                <MudTh>Invoice #</MudTh>
                <MudTh>Amount</MudTh>
                <MudTh>Method</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Date</MudTh>
                <MudTh>Reference</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Invoice #">@(context.InvoiceNumber ?? "-")</MudTd>
                <MudTd DataLabel="Amount">@context.Amount.ToString("C2")</MudTd>
                <MudTd DataLabel="Method">@context.Method</MudTd>
                <MudTd DataLabel="Status">@context.Status</MudTd>
                <MudTd DataLabel="Date">@context.PaymentDate.ToString("d")</MudTd>
                <MudTd DataLabel="Reference">@(context.TransactionReference ?? "-")</MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudContainer>

@code {
    private bool _loading = true;
    private List<PaymentDto> _payments = new();

    protected override async Task OnInitializedAsync()
    {
        _payments = (await PaymentService.GetAllPaymentsAsync()).ToList();
        _loading = false;
    }
}
