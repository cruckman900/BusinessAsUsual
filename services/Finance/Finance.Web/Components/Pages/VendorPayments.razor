@page "/finance/payables/vendor-payments"

<PageTitle>Vendor Payments</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-2 pa-0">
    <div class="mb-3">
        <MudLink Href="/dashboard">Dashboard</MudLink>
        <span class="mx-2">/</span>
        <MudLink Href="/finance">Finance</MudLink>
        <span class="mx-2">/</span>
        <MudLink Href="/finance/payables">Accounts Payable</MudLink>
        <span class="mx-2">/</span>
        <MudText Typo="Typo.body2" Inline="true" Color="Color.Primary">Vendor Payments</MudText>
    </div>

    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h4" GutterBottom="true">
                <MudIcon Icon="@Icons.Material.Filled.Payment" Class="mr-2" />
                Vendor Payments
            </MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">Schedule and issue payments to vendors</MudText>
        </div>
    </div>

    <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Construction">
        Vendor Payments is coming soon. This submodule is scaffolded and ready for data wiring.
    </MudAlert>
</MudContainer>
