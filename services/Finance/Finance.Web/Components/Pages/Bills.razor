@page "/finance/payables/bills"

<PageTitle>Bills</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-2 pa-0">
    <div class="mb-3">
        <MudLink Href="/dashboard">Dashboard</MudLink>
        <span class="mx-2">/</span>
        <MudLink Href="/finance">Finance</MudLink>
        <span class="mx-2">/</span>
        <MudLink Href="/finance/payables">Accounts Payable</MudLink>
        <span class="mx-2">/</span>
        <MudText Typo="Typo.body2" Inline="true" Color="Color.Primary">Bills</MudText>
    </div>

    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h4" GutterBottom="true">
                <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" />
                Bills
            </MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">Record and manage vendor bills</MudText>
        </div>
    </div>

    <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Construction">
        Bills is coming soon. This submodule is scaffolded and ready for data wiring.
    </MudAlert>
</MudContainer>
