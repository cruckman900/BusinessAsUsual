{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EventBus": {
    "//": "Provider = InProcess (default) | Broker. Broker uses RabbitMQ via MassTransit (Amazon MQ for RabbitMQ on AWS).",
    "Provider": "InProcess",
    "RabbitMq": {
      "Host": "localhost",
      "Port": 5672,
      "VirtualHost": "/",
      "Username": "guest",
      "Password": "guest",
      "UseSsl": false,
      "RetryLimit": 5
    }
  }
}
