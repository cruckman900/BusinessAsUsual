@page "/hr"
@page "/hr/home"
@inject IJSRuntime JS
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-2 pa-0">
    <div class="mb-3">
        <MudLink Href="/dashboard">Dashboard</MudLink>
        <span class="mx-2">/</span>
        <MudText Typo="Typo.body2" Inline="true" Color="Color.Primary">HR</MudText>
    </div>

    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" />
        Human Resources
    </MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        Manage your organization's most valuable asset - your people
    </MudText>

    <!-- Main Module Cards Grid -->
    <MudGrid Spacing="3" Class="mb-6">
        <!-- Employee Management -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Primary" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Employee Management</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        View and manage employee records, contact details, and employment history
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">156 Active</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/hr/employees">
                        View Employees
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Departments -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Color="Color.Success" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Departments</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Organize your company structure and departmental hierarchies
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">12 Departments</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/hr/departments">
                        View Departments
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Recruiting -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.PersonSearch" Size="Size.Large" Color="Color.Info" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Recruiting</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Manage candidates, track applications, and schedule interviews
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">23 Active</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/hr/applicants">
                        View Applicants
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Performance Management -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Large" Color="Color.Warning" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Performance</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Track reviews, goals, and employee performance metrics
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">8 Overdue</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/hr/reviews">
                        View Reviews
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Training -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Large" Color="Color.Tertiary" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Training</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Course catalog, certifications, and learning development
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Text">15 Courses</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/hr/courses">
                        View Courses
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Timekeeping -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Large" Color="Color.Secondary" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Timekeeping</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Time tracking, timesheets, and approval workflows
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text">12 Pending</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/hr/timesheets">
                        View Timesheets
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Onboarding & Benefits -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Size="Size.Large" Color="Color.Info" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">HR Administration</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Onboarding workflows and benefits administration
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">5 New Hires</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/hr/onboarding">
                        View Onboarding
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Reports -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                <MudCardContent Class="text-center pa-6 flex-grow-1">
                    <MudIcon Icon="@Icons.Material.Filled.BarChart" Size="Size.Large" Color="Color.Dark" Class="mb-4" />
                    <MudText Typo="Typo.h6" GutterBottom="true">Reports & Analytics</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Comprehensive HR analytics, reports, and dashboards
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Dark" Variant="Variant.Text">11 Reports</MudChip>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/hr/reports">
                        View Reports
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>

    <!-- Quick Stats Row -->
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudText Typo="Typo.h6" GutterBottom="true">
            <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
            Quick Stats
        </MudText>
        <MudGrid Spacing="2">
            <MudItem xs="6" sm="3">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4" Color="Color.Primary">156</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total Employees</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4" Color="Color.Info">23</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Active Applicants</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4" Color="Color.Warning">8</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Overdue Reviews</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4" Color="Color.Error">12</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Pending Approvals</MudText>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- About & Module Info Grid -->
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4 d-flex flex-column" Elevation="1" Style="height: 100%;">
                <MudText Typo="Typo.h6" GutterBottom="true">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                    About HR Module
                </MudText>
                <MudText Typo="Typo.body2" Class="mb-4">
                    The Human Resources module provides comprehensive workforce management capabilities including:
                </MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Employee Management</strong> - Track employee information, contact details, and employment history
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Department Organization</strong> - Structure your organization with departments and hierarchies
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Recruiting</strong> - Manage candidate pipeline from application to hire
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Performance Management</strong> - Track reviews, goals, and employee development
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Training & Development</strong> - Course catalog, certifications, and learning management
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Timekeeping</strong> - Time tracking, timesheets, and approval workflows
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Onboarding & Benefits</strong> - Streamline new hire processes and benefits administration
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                        <strong>Analytics & Reporting</strong> - Comprehensive HR reports and dashboards
                    </MudListItem>
                </MudList>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-auto pt-4">
                    This module is dynamically loaded via the Module Registry Service and provides both web UI and mobile API contracts.
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 d-flex flex-column" Elevation="1" Style="height: 100%;">
                <MudText Typo="Typo.h6" GutterBottom="true">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
                    Module Info
                </MudText>
                <MudStack Spacing="2" Class="flex-grow-1">
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Module ID</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Filled">hr</MudChip>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Version</MudText>
                        <MudText Typo="Typo.body2">2.0.0</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total Pages</MudText>
                        <MudText Typo="Typo.body2">32 pages</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">API Port</MudText>
                        <MudText Typo="Typo.body2">5041</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Web UI Port</MudText>
                        <MudText Typo="Typo.body2">5002</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Mobile Support</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Yes</MudChip>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Complete</MudChip>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .mud-card-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15) !important;
    }
</style>

@code {
    // Navigation is now fully automatic via NavigationInterceptor!
    // No manual OnAfterRenderAsync needed
    // Clicks on links and NavigationManager calls are automatically intercepted
}

