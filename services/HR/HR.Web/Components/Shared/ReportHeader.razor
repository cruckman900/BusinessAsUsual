@inject NavigationManager Navigation

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <div class="mb-2">
            <MudTooltip Text="Back to Reports Dashboard">
                <MudButton Variant="Variant.Text" 
                           StartIcon="@Icons.Material.Filled.ArrowBack" 
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="@(() => Navigation.NavigateTo("/hr/reports"))">
                    Reports
                </MudButton>
            </MudTooltip>
        </div>
        <MudText Typo="Typo.h4" GutterBottom="true">
            <MudIcon Icon="@Icon" Class="mr-2" />
            @Title
        </MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">@Subtitle</MudText>
    </div>
    @if (ShowActions)
    {
        <div>
            @Actions
        </div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Subtitle { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Assessment;
    [Parameter] public bool ShowActions { get; set; } = true;
    [Parameter] public RenderFragment? Actions { get; set; }
}
