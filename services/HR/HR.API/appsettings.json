{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EventBus": {
    "//": "Provider = InProcess (default) | Broker. Broker uses RabbitMQ via MassTransit (Amazon MQ for RabbitMQ on AWS).",
    "Provider": "InProcess",
    "RabbitMq": {
      "Host": "localhost",
      "VirtualHost": "/",
      "Username": "guest",
      "Password": "guest",
      "RetryLimit": 5
    }
  },
  "ModuleRegistry": {
    "Url": "http://localhost:5100"
  },
  "HR": {
    "ApiBaseUrl": "http://localhost:5041",
    "UiEntryPoint": "http://localhost:5002"
  }
}
