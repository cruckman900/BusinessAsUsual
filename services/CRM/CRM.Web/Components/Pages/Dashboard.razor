@page "/crm"
@page "/crm/home"
@inject ILeadService LeadService
@inject IOpportunityService OpportunityService
@inject ICustomerService CustomerService
@inject NavigationManager Navigation

<PageTitle>CRM</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-2 pa-0">
    <div class="mb-3">
        <MudLink Href="/dashboard">Dashboard</MudLink>
        <span class="mx-2">/</span>
        <MudText Typo="Typo.body2" Inline="true" Color="Color.Primary">CRM</MudText>
    </div>

    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.Handshake" Class="mr-2" />
        Customer Relationship Management
    </MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        Manage leads, track opportunities, and nurture customer relationships
    </MudText>

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <!-- Main Module Cards Grid -->
        <MudGrid Spacing="3" Class="mb-6">
            <!-- Leads -->
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                    <MudCardContent Class="text-center pa-6 flex-grow-1">
                        <MudIcon Icon="@Icons.Material.Filled.PersonSearch" Size="Size.Large" Color="Color.Primary" Class="mb-4" />
                        <MudText Typo="Typo.h6" GutterBottom="true">Leads</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                            Capture and qualify potential customers from various sources
                        </MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">@_totalLeads Active</MudChip>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/crm/leads">
                            View Leads
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Opportunities -->
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                    <MudCardContent Class="text-center pa-6 flex-grow-1">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Large" Color="Color.Success" Class="mb-4" />
                        <MudText Typo="Typo.h6" GutterBottom="true">Opportunities</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                            Track sales pipeline and manage deals through close
                        </MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">@_activeOpportunities Active</MudChip>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/crm/opportunities">
                            View Pipeline
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Customers -->
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                    <MudCardContent Class="text-center pa-6 flex-grow-1">
                        <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" Color="Color.Info" Class="mb-4" />
                        <MudText Typo="Typo.h6" GutterBottom="true">Customers</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                            Maintain customer profiles, contacts, and account history
                        </MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@_totalCustomers Total</MudChip>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/crm/customers">
                            View Customers
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Activities -->
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                    <MudCardContent Class="text-center pa-6 flex-grow-1">
                        <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Large" Color="Color.Warning" Class="mb-4" />
                        <MudText Typo="Typo.h6" GutterBottom="true">Activities</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                            Log calls, meetings, emails, and other customer interactions
                        </MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">✓ Live</MudChip>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/crm/activities">
                            View Activities
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Reports -->
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                    <MudCardContent Class="text-center pa-6 flex-grow-1">
                        <MudIcon Icon="@Icons.Material.Filled.BarChart" Size="Size.Large" Color="Color.Tertiary" Class="mb-4" />
                        <MudText Typo="Typo.h6" GutterBottom="true">Reports & Analytics</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                            Sales forecasting, pipeline analytics, and performance metrics
                        </MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">✓ Live</MudChip>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/crm/reports">
                            View Reports
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Settings -->
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Class="mud-card-hover d-flex flex-column" Style="height: 100%;">
                    <MudCardContent Class="text-center pa-6 flex-grow-1">
                        <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Large" Color="Color.Dark" Class="mb-4" />
                        <MudText Typo="Typo.h6" GutterBottom="true">Settings</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                            Configure stages, statuses, fields, and CRM preferences
                        </MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text">Coming Soon</MudChip>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/crm/settings">
                            Configure
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>

        <!-- Quick Stats Row -->
        <MudPaper Class="pa-4 mb-4" Elevation="1">
            <MudText Typo="Typo.h6" GutterBottom="true">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
                Quick Stats
            </MudText>
            <MudGrid Spacing="2">
                <MudItem xs="6" sm="3">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h4" Color="Color.Primary">@_totalLeads</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total Leads</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h4" Color="Color.Success">@_activeOpportunities</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Active Opportunities</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h4" Color="Color.Info">@_totalCustomers</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total Customers</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h4" Color="Color.Warning">@_pipelineValue.ToString("C0")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Pipeline Value</MudText>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <!-- About & Module Info Grid -->
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-4 d-flex flex-column" Elevation="1" Style="height: 100%;">
                    <MudText Typo="Typo.h6" GutterBottom="true">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                        About CRM Module
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mb-4">
                        The Customer Relationship Management module provides comprehensive sales and customer management capabilities including:
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                            <strong>Lead Management</strong> - Capture leads from multiple sources and track qualification progress
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                            <strong>Sales Pipeline</strong> - Manage opportunities through each stage with probability tracking
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                            <strong>Customer Management</strong> - Maintain detailed customer profiles and interaction history
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                            <strong>Reporting & Analytics</strong> - Interactive charts with sales pipeline, forecasts, and KPIs ✓
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Check">
                            <strong>Activity Tracking</strong> - Timeline view with calls, meetings, emails, and tasks ✓
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Schedule">
                            <strong>Email Templates</strong> - Marketing campaigns and automated follow-ups (Coming Soon)
                        </MudListItem>
                    </MudList>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-auto pt-4">
                        This module is dynamically loaded via the Module Registry Service and provides both web UI and mobile API contracts.
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4 d-flex flex-column" Elevation="1" Style="height: 100%;">
                    <MudText Typo="Typo.h6" GutterBottom="true">
                        <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
                        Module Info
                    </MudText>
                    <MudStack Spacing="2" Class="flex-grow-1">
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Module ID</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Filled">crm</MudChip>
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Version</MudText>
                            <MudText Typo="Typo.body2">1.0.0</MudText>
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Total Pages</MudText>
                            <MudText Typo="Typo.body2">10 pages</MudText>
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">API Port</MudText>
                            <MudText Typo="Typo.body2">5004</MudText>
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Web UI Port</MudText>
                            <MudText Typo="Typo.body2">5003</MudText>
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Mobile Support</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Yes</MudChip>
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">In Development</MudChip>
                        </div>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

<style>
    .mud-card-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15) !important;
    }
</style>

@code {
    private bool _loading = true;
    private int _totalLeads;
    private int _activeOpportunities;
    private int _totalCustomers;
    private decimal _pipelineValue;

    protected override async Task OnInitializedAsync()
    {
        var leads = await LeadService.GetAllLeadsAsync();
        var opportunities = await OpportunityService.GetAllOpportunitiesAsync();
        var customers = await CustomerService.GetAllCustomersAsync();

        _totalLeads = leads.Count();
        _activeOpportunities = opportunities.Count(o => !o.IsWon && !o.IsLost);
        _totalCustomers = customers.Count();
        _pipelineValue = opportunities.Where(o => !o.IsWon && !o.IsLost).Sum(o => o.Amount);

        _loading = false;
    }
}
