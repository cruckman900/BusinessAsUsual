@page "/crm/pipeline"
@using CRM.Application.DTOs
@using CRM.Domain.Enums
@inject IOpportunityService OpportunityService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Sales Pipeline</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-2 pa-0">
    <div class="mb-3">
        <MudLink Href="/dashboard">Dashboard</MudLink>
        <span class="mx-2">/</span>
        <MudLink Href="/crm">CRM</MudLink>
        <span class="mx-2">/</span>
        <MudText Typo="Typo.body2" Inline="true" Color="Color.Primary">Pipeline</MudText>
    </div>

    <!-- Header -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h4" Class="flex-grow-1">
            <MudIcon Icon="@Icons.Material.Filled.ViewKanban" Class="mr-2" />
            Sales Pipeline
        </MudText>
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search opportunities..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      Class="mr-2"
                      Style="max-width: 280px;" />
        <MudSelect T="string" @bind-Value="_ownerFilter" Label="Owner" Dense="true"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Class="mr-2" Style="max-width: 180px;">
            <MudSelectItem T="string" Value="@("All")">All Owners</MudSelectItem>
            @foreach (var owner in _owners)
            {
                <MudSelectItem T="string" Value="@owner">@owner</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="string" @bind-Value="_closeFilter" Label="Close Date" Dense="true"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Class="mr-2" Style="max-width: 170px;">
            <MudSelectItem T="string" Value="@("All")">Any Time</MudSelectItem>
            <MudSelectItem T="string" Value="@("Overdue")">Overdue</MudSelectItem>
            <MudSelectItem T="string" Value="@("30")">Next 30 days</MudSelectItem>
            <MudSelectItem T="string" Value="@("90")">Next 90 days</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => Navigation.NavigateTo("/crm/opportunities/new"))">
            Add Opportunity
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Drag an opportunity card between columns to move it through the sales stages.
        </MudText>

        <MudDropContainer T="OpportunityDto"
                          Items="_opportunities"
                          ItemsSelector="@((item, column) => item.Stage == column && MatchesFilters(item))"
                          ItemDropped="OnItemDropped"
                          Class="pipeline-board">
            <ChildContent>
                <div class="pipeline-columns">
                    @foreach (var stage in _stages)
                    {
                        var stageItems = FilteredForStage(stage.Value);
                        var columnCount = stageItems.Count;
                        var columnValue = stageItems.Sum(o => o.Amount);
                        <div class="pipeline-column">
                            <MudPaper Elevation="1" Class="pipeline-column-header pa-3" Style="@ColumnHeaderStyle(stage.Color)">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@stage.Label</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="stage.Color" Variant="Variant.Filled">@columnCount</MudChip>
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@columnValue.ToString("C0")</MudText>
                            </MudPaper>
                            <MudDropZone T="OpportunityDto"
                                         Identifier="@stage.Value"
                                         Class="pipeline-dropzone"
                                         AllowReorder="false" />
                        </div>
                    }
                </div>
            </ChildContent>
            <ItemRenderer>
                <MudCard Elevation="2" Class="pipeline-card">
                    <MudCardContent Class="pa-3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="1">
                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold" @onclick="@(() => OpenOpportunity(context.Id))" Style="cursor: pointer; flex: 1 1 auto;">@context.Name</MudText>
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                                     Size="Size.Small"
                                     Dense="true"
                                     AnchorOrigin="Origin.BottomRight"
                                     TransformOrigin="Origin.TopRight">
                                <MudMenuItem Icon="@Icons.Material.Filled.Visibility" OnClick="@(() => OpenOpportunity(context.Id))">View</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => OpenOpportunity(context.Id))">Edit</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Email" OnClick="@(() => SendEmail(context))">Send Email</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(() => DeleteOpportunity(context))">Delete</MudMenuItem>
                            </MudMenu>
                        </MudStack>
                        @if (!string.IsNullOrWhiteSpace(context.CustomerName))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Class="mr-1" Style="vertical-align: text-bottom;" />
                                @context.CustomerName
                            </MudText>
                        }
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mt-2">
                            <MudText Typo="Typo.body2" Class="font-weight-bold">@context.Amount.ToString("C0")</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@ProbabilityColor(context.Probability)" Variant="Variant.Text">
                                @context.Probability%
                            </MudChip>
                        </MudStack>
                        <MudProgressLinear Color="@ProbabilityColor(context.Probability)"
                                           Value="@((double)context.Probability)"
                                           Class="mt-1"
                                           Rounded="true" />
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mt-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudTooltip Text="@(string.IsNullOrWhiteSpace(context.AssignedToEmployeeName) ? "Unassigned" : context.AssignedToEmployeeName)">
                                    <MudAvatar Size="Size.Small" Color="@AvatarColor(context.AssignedToEmployeeName)" Variant="Variant.Filled">
                                        @Initials(context.AssignedToEmployeeName)
                                    </MudAvatar>
                                </MudTooltip>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" Style="vertical-align: text-bottom;" />
                                    @context.DaysInStage d
                                </MudText>
                            </MudStack>
                            @if (context.ExpectedCloseDate.HasValue)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @context.ExpectedCloseDate.Value.ToString("MMM dd")
                                </MudText>
                            }
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </ItemRenderer>
        </MudDropContainer>
    }
</MudContainer>

<style>
    .pipeline-board {
        width: 100%;
        overflow-x: auto;
    }

    .pipeline-columns {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        min-width: min-content;
        padding-bottom: 12px;
    }

    .pipeline-column {
        display: flex;
        flex-direction: column;
        min-width: 260px;
        max-width: 300px;
        flex: 1 1 0;
    }

    .pipeline-column-header {
        border-radius: 8px 8px 0 0;
        border-bottom: 3px solid var(--pipeline-accent, transparent);
    }

    .pipeline-dropzone {
        min-height: 120px;
        background-color: var(--mud-palette-background-grey);
        border-radius: 0 0 8px 8px;
        padding: 8px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex-grow: 1;
    }

    .pipeline-card {
        cursor: grab;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

        .pipeline-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15) !important;
        }

    .mud-drop-item-dragging {
        opacity: 0.6;
    }
</style>

@code {
    private bool _loading = true;
    private string _searchString = "";
    private string _ownerFilter = "All";
    private string _closeFilter = "All";
    private List<OpportunityDto> _opportunities = new();

    private List<string> _owners => _opportunities
        .Select(o => o.AssignedToEmployeeName)
        .Where(n => !string.IsNullOrWhiteSpace(n))
        .Select(n => n!)
        .Distinct()
        .OrderBy(n => n)
        .ToList();

    private record StageColumn(OpportunityStage Stage, string Value, string Label, Color Color);

    // Columns mirror the OpportunityStage enum. Value matches the DTO's Stage string
    // (produced via enum.ToString()), so items land in the correct column.
    private readonly List<StageColumn> _stages = new()
    {
        new(OpportunityStage.Prospecting, nameof(OpportunityStage.Prospecting), "Prospecting", Color.Info),
        new(OpportunityStage.Qualification, nameof(OpportunityStage.Qualification), "Qualification", Color.Primary),
        new(OpportunityStage.NeedsAnalysis, nameof(OpportunityStage.NeedsAnalysis), "Needs Analysis", Color.Tertiary),
        new(OpportunityStage.Proposal, nameof(OpportunityStage.Proposal), "Proposal", Color.Warning),
        new(OpportunityStage.Negotiation, nameof(OpportunityStage.Negotiation), "Negotiation", Color.Secondary),
        new(OpportunityStage.ClosedWon, nameof(OpportunityStage.ClosedWon), "Closed Won", Color.Success),
        new(OpportunityStage.ClosedLost, nameof(OpportunityStage.ClosedLost), "Closed Lost", Color.Error),
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadOpportunities();
    }

    private async Task LoadOpportunities()
    {
        try
        {
            var opportunities = await OpportunityService.GetAllOpportunitiesAsync();
            _opportunities = opportunities.ToList();
        }
        finally
        {
            _loading = false;
        }
    }

    private List<OpportunityDto> FilteredForStage(string stageValue) =>
        _opportunities
            .Where(o => o.Stage == stageValue)
            .Where(o => string.IsNullOrWhiteSpace(_searchString)
                || o.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
                || (o.CustomerName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false))
            .Where(o => _ownerFilter == "All" || o.AssignedToEmployeeName == _ownerFilter)
            .Where(o => MatchesCloseFilter(o))
            .ToList();

    private bool MatchesCloseFilter(OpportunityDto o)
    {
        if (_closeFilter == "All") return true;
        var close = o.ExpectedCloseDate;
        if (close is null) return false;
        var today = DateTime.Today;
        return _closeFilter switch
        {
            "Overdue" => close.Value.Date < today,
            "30" => close.Value.Date >= today && close.Value.Date <= today.AddDays(30),
            "90" => close.Value.Date >= today && close.Value.Date <= today.AddDays(90),
            _ => true
        };
    }

    private async Task OnItemDropped(MudItemDropInfo<OpportunityDto> dropInfo)
    {
        var item = dropInfo.Item;
        if (item is null) return;

        var newStageValue = dropInfo.DropzoneIdentifier;
        if (item.Stage == newStageValue) return;

        if (!Enum.TryParse<OpportunityStage>(newStageValue, out var newStage)) return;

        var previousStage = item.Stage;
        item.Stage = newStageValue; // optimistic UI update

        try
        {
            await OpportunityService.UpdateOpportunityAsync(item.Id, new UpdateOpportunityRequest
            {
                Name = item.Name,
                CustomerId = item.CustomerId,
                Stage = newStage,
                Amount = item.Amount,
                Probability = item.Probability,
                ExpectedCloseDate = item.ExpectedCloseDate,
                Description = item.Description,
                AssignedToEmployeeId = item.AssignedToEmployeeId,
                LostReason = item.LostReason,
                CompetitorName = item.CompetitorName,
                ProductCategory = item.ProductCategory,
                ProductDescription = item.ProductDescription,
                Quantity = item.Quantity,
                Tags = item.Tags,
            });

            Snackbar.Add($"'{item.Name}' moved to {NamedStage(newStageValue)}", Severity.Success);
        }
        catch (Exception)
        {
            item.Stage = previousStage; // revert on failure
            Snackbar.Add("Failed to move opportunity. Please try again.", Severity.Error);
        }
    }

    private void OpenOpportunity(string id) => Navigation.NavigateTo($"/crm/opportunities/{id}");

    private async Task SendEmail(OpportunityDto opp)
    {
        var parameters = new DialogParameters
        {
            { nameof(SendEmailDialog.Opportunity), opp },
            { nameof(SendEmailDialog.SenderName), opp.AssignedToEmployeeName ?? "" }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<SendEmailDialog>($"Email — {opp.Name}", parameters, options);
    }

    private bool MatchesFilters(OpportunityDto o) =>
        (string.IsNullOrWhiteSpace(_searchString)
            || o.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || (o.CustomerName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false))
        && (_ownerFilter == "All" || o.AssignedToEmployeeName == _ownerFilter)
        && MatchesCloseFilter(o);

    private async Task DeleteOpportunity(OpportunityDto opp)
    {
        try
        {
            await OpportunityService.DeleteOpportunityAsync(opp.Id);            _opportunities.RemoveAll(o => o.Id == opp.Id);
            Snackbar.Add($"'{opp.Name}' deleted", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to delete opportunity.", Severity.Error);
        }
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..1].ToUpperInvariant();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }

    private static Color AvatarColor(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return Color.Default;
        var palette = new[] { Color.Primary, Color.Secondary, Color.Info, Color.Success, Color.Warning, Color.Tertiary };
        var index = Math.Abs(name.GetHashCode()) % palette.Length;
        return palette[index];
    }

    private string NamedStage(string stageValue) =>
        _stages.FirstOrDefault(s => s.Value == stageValue)?.Label ?? stageValue;

    private static string ColumnHeaderStyle(Color color) =>
        $"--pipeline-accent: var(--mud-palette-{ColorToken(color)});";

    private static string ColorToken(Color color) => color switch
    {
        Color.Info => "info",
        Color.Primary => "primary",
        Color.Tertiary => "tertiary",
        Color.Warning => "warning",
        Color.Secondary => "secondary",
        Color.Success => "success",
        Color.Error => "error",
        _ => "default"
    };

    private static Color ProbabilityColor(decimal probability) => probability switch
    {
        >= 75 => Color.Success,
        >= 40 => Color.Warning,
        _ => Color.Error
    };
}
