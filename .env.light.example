# =============================================================================
# LIGHT INSTANCE environment file  (copy to ".env" on the t3.micro instance)
# -----------------------------------------------------------------------------
#   cp .env.light.example .env      # then fill in the real values
#   docker compose -f docker-compose.light.yml up -d --build
#
# Do NOT commit the real .env - it holds database credentials and API keys.
# =============================================================================

# ASP.NET Core environment (Production is recommended on the instances)
ASPNETCORE_ENVIRONMENT=Production

# --- Module Registry -------------------------------------------------------
# Set to false to persist the registry in the shared RDS; true keeps it in-memory
# (registrations are lost on restart, which is usually fine for discovery).
MRS_USE_INMEMORY=false
# Example:
# Server=bau-db.abc123.us-east-1.rds.amazonaws.com,1433;Database=BusinessAsUsual_ModuleRegistry;User Id=admin;Password=CHANGE_ME;Encrypt=True;TrustServerCertificate=True;
MRS_SQL_CONNECTION_STRING=

# --- AI.Api ----------------------------------------------------------------
# Paid-tier company gate reads the provisioning master DB on the shared RDS.
AWS_SQL_CONNECTION_STRING=

# Demo tier: GitHub Models personal access token (github_pat_...)
AI_DEMO_APIKEY=

# Paid tier: Amazon Bedrock. Prefer attaching an IAM role with bedrock:InvokeModel
# to this instance instead of static AWS keys.
AI_PAID_PROVIDER=Bedrock
AI_PAID_REGION=us-east-1
AI_PAID_MODEL=anthropic.claude-3-haiku-20240307-v1:0
