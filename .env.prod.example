# =============================================================================
# MAIN INSTANCE environment file  (copy to ".env" on the existing EC2 instance)
# -----------------------------------------------------------------------------
#   cp .env.prod.example .env       # then fill in the real values
#   docker compose -f docker-compose.prod.yml up -d --build
#
# The deploy-docker.yml workflow also injects AWS_SQL_CONNECTION_STRING from the
# repository secret, so you can keep that one out of the on-box .env if you prefer.
#
# Do NOT commit the real .env - it holds database credentials.
# =============================================================================

# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Production

# --- Shared RDS (MS SQL) --------------------------------------------------
# Example:
# Server=bau-db.abc123.us-east-1.rds.amazonaws.com,1433;Database=BusinessAsUsual;User Id=admin;Password=CHANGE_ME;Encrypt=True;TrustServerCertificate=True;
AWS_SQL_CONNECTION_STRING=

# --- Cross-instance service URLs (LIGHT instance private IP/DNS) -----------
# The Web shell discovers modules via the Module Registry and calls the AI
# service; both run on the LIGHT instance. Use its PRIVATE IP inside the VPC.
MODULE_REGISTRY_URL=http://LIGHT_INSTANCE_PRIVATE_IP:5100
AI_SERVICE_URL=http://LIGHT_INSTANCE_PRIVATE_IP:5300
