@implements IDisposable
@inject IJSRuntime JS

<div class="footer-section footer-timeclock">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudTooltip Text="@(_clockedIn ? "Clock out" : "Clock in")">
            <MudButton Variant="Variant.Filled"
                       Size="Size.Small"
                       Color="@(_clockedIn ? Color.Error : Color.Success)"
                       StartIcon="@(_clockedIn ? Icons.Material.Filled.StopCircle : Icons.Material.Filled.PlayCircle)"
                       OnClick="ToggleClock">
                @(_clockedIn ? "Clock Out" : "Clock In")
            </MudButton>
        </MudTooltip>

        <MudStack Spacing="0" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.subtitle2" Color="@TimeColor" Style="font-variant-numeric: tabular-nums; line-height: 1.1;">
                @FormatElapsed(Elapsed)
            </MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="line-height: 1;">
                @StatusText
            </MudText>
        </MudStack>

        @if (IsNearLimit)
        {
            <MudTooltip Text="@LimitTooltip">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="@TimeColor" Size="Size.Small" />
            </MudTooltip>
        }
    </MudStack>
</div>

@code {
    private static readonly TimeSpan DailyLimit = TimeSpan.FromHours(8);
    private static readonly TimeSpan WarningThreshold = TimeSpan.FromHours(7);

    private bool _clockedIn;
    private DateTime _sessionStart;
    private TimeSpan _accumulated = TimeSpan.Zero;
    private System.Threading.Timer? _timer;

    private TimeSpan Elapsed =>
        _clockedIn ? _accumulated + (DateTime.Now - _sessionStart) : _accumulated;

    private bool IsNearLimit => Elapsed >= WarningThreshold;

    private Color TimeColor =>
        Elapsed >= DailyLimit ? Color.Error :
        Elapsed >= WarningThreshold ? Color.Warning :
        Color.Primary;

    private string StatusText =>
        _clockedIn ? "Clocked in" : "Clocked out";

    private string LimitTooltip =>
        Elapsed >= DailyLimit
            ? "You have reached 8 hours for today"
            : $"Approaching 8 hours ({FormatElapsed(DailyLimit - Elapsed)} remaining)";

    private void ToggleClock()
    {
        if (_clockedIn)
        {
            _accumulated += DateTime.Now - _sessionStart;
            _clockedIn = false;
            StopTimer();
        }
        else
        {
            _sessionStart = DateTime.Now;
            _clockedIn = true;
            StartTimer();
        }

        _ = SaveStateAsync();
    }

    private void StartTimer()
    {
        _timer ??= new System.Threading.Timer(
            _ => InvokeAsync(StateHasChanged),
            null,
            TimeSpan.FromSeconds(1),
            TimeSpan.FromSeconds(1));
    }

    private void StopTimer()
    {
        _timer?.Dispose();
        _timer = null;
    }

    private static string FormatElapsed(TimeSpan value)
    {
        if (value < TimeSpan.Zero)
        {
            value = TimeSpan.Zero;
        }

        return $"{(int)value.TotalHours:00}:{value.Minutes:00}:{value.Seconds:00}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await LoadStateAsync();
    }

    private async Task LoadStateAsync()
    {
        TimeClockState? state = null;
        try
        {
            state = await JS.InvokeAsync<TimeClockState?>("timeClock.load");
        }
        catch
        {
            // storage unavailable — start fresh
        }

        var today = DateTime.Now.ToString("yyyy-MM-dd");

        if (state is not null && state.Date == today)
        {
            _accumulated = TimeSpan.FromSeconds(Math.Max(0, state.AccumulatedSeconds));

            if (state.ClockedIn && DateTime.TryParse(state.SessionStart, out var start))
            {
                _sessionStart = start;
                _clockedIn = true;
                StartTimer();
            }
        }
        else if (state is not null)
        {
            // Stale day — reset and persist a clean slate
            await SaveStateAsync();
        }

        StateHasChanged();
    }

    private async Task SaveStateAsync()
    {
        var state = new TimeClockState
        {
            Date = DateTime.Now.ToString("yyyy-MM-dd"),
            AccumulatedSeconds = _accumulated.TotalSeconds,
            ClockedIn = _clockedIn,
            SessionStart = _clockedIn ? _sessionStart.ToString("o") : null
        };

        try
        {
            await JS.InvokeVoidAsync("timeClock.save", state);
        }
        catch
        {
            // ignore storage errors
        }
    }

    private sealed class TimeClockState
    {
        public string Date { get; set; } = string.Empty;
        public double AccumulatedSeconds { get; set; }
        public bool ClockedIn { get; set; }
        public string? SessionStart { get; set; }
    }

    public void Dispose() => StopTimer();
}
