@using BusinessAsUsual.Web.Modules._Shared
@inject IConfiguration Configuration
@* ============================
   DESKTOP TOP BAR
   ============================ *@
<MudHidden Breakpoint="Breakpoint.SmAndDown">
    <div class="topbar-inner">
        <div class="brand">
            <img src="images/logo.png" alt="BAU Logo" class="brand-logo" />
            <MudText Typo="Typo.h6">Business As Usual</MudText>
        </div>

        <MudSpacer />

        <div class="module-nav">
            <MudNavLink Href="/dashboard"
                        Match="NavLinkMatch.All"
                        Class="topnav-link">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="me-1" />
                Dashboard
            </MudNavLink>
            @foreach (var module in Modules)
            {
                <MudNavLink Href="@module.Route"
                            Match="NavLinkMatch.Prefix"
                            Class="topnav-link">
                    <MudIcon Icon="@module.Icon" Class="me-1" />
                    @module.Name
                </MudNavLink>
            }
            <MudMenu Label="More" Dense="true">
                @foreach (var module in OverflowModules)
                {
                    <MudMenuItem Href="@module.Route">
                        <MudIcon Icon="@module.Icon" Class="me-1" />
                        @module.Name
                    </MudMenuItem>
                }
            </MudMenu>
        </div>

        <MudSpacer />
        <TenantDisplay CurrentTenant="@CurrentTenant" />
        <UserMenu />
        <!-- AI Assistant toggle is injected here so it's always available but unobtrusive -->
        <div class="ai-assistant-host">
            <AiAssistant CompanyId="@AiTestCompanyId" />
        </div>
    </div>
</MudHidden>


@* ============================
   MOBILE TOP BAR (Hamburger)
   ============================ *@
<MudHidden Breakpoint="Breakpoint.MdAndUp">
    <div class="topbar-mobile">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       OnClick="@(() => _mobileMenuOpen = true)" />

        <MudText Typo="Typo.h6">Business As Usual</MudText>

        <MudSpacer />

        <UserMenu />
    </div>
</MudHidden>


@* ============================
   MOBILE DRAWER
   ============================ *@
<MudDrawer @bind-Open="_mobileMenuOpen"
           Anchor="Anchor.Left"
           Variant="DrawerVariant.Temporary"
           Elevation="2"
           Width="280px"
           Class="mobile-nav-drawer">

    <div class="mobile-nav-header">
        <div class="mobile-nav-brand">
            <img src="images/logo.png" alt="BAU Logo" class="brand-logo" />
            <MudText Typo="Typo.subtitle1">Business As Usual</MudText>
        </div>
        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       Size="Size.Small"
                       Color="Color.Inherit"
                       OnClick="@CloseMobileMenu"
                       aria-label="Close menu" />
    </div>

    <MudDivider />

    <MudNavMenu Class="mobile-nav-menu">
        <MudNavLink Href="/dashboard"
                    Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.Dashboard"
                    OnClick="@CloseMobileMenu">
            Dashboard
        </MudNavLink>
        @foreach (var module in Modules)
        {
            <MudNavLink Href="@module.Route"
                        Match="NavLinkMatch.Prefix"
                        Icon="@module.Icon"
                        OnClick="@CloseMobileMenu">
                @module.Name
            </MudNavLink>
        }
        @foreach (var module in OverflowModules)
        {
            <MudNavLink Href="@module.Route"
                        Match="NavLinkMatch.Prefix"
                        Icon="@module.Icon"
                        OnClick="@CloseMobileMenu">
                @module.Name
            </MudNavLink>
        }
    </MudNavMenu>

    <MudSpacer />

    <MudDivider />

    <div class="mobile-nav-footer">
        <TenantSelector Compact="true" />
        <UserMenu Compact="true" />
    </div>
</MudDrawer>


@code {

    [Parameter] public IEnumerable<ModuleDefinition> Modules { get; set; } = Enumerable.Empty<ModuleDefinition>();
    [Parameter] public IEnumerable<ModuleDefinition> OverflowModules { get; set; } = Enumerable.Empty<ModuleDefinition>();
    [Parameter] public string? CurrentModule { get; set; }
    [Parameter] public string? CurrentTenant { get; set; }
    [Parameter] public EventCallback OnToggleSidebar { get; set; }

    private bool _mobileMenuOpen = false;

    void CloseMobileMenu() => _mobileMenuOpen = false;

    /// <summary>
    /// Optional test company id for the AI assistant. Populated only from the development
    /// config key "AiService:TestCompanyId" so paid-tier routing can be exercised from the UI.
    /// The key is absent in production, so this stays null and the assistant uses the demo tier.
    /// Replace with the authenticated user's real company id once auth is wired up.
    /// </summary>
    // TODO (auth): Replace this dev-only config lookup with the authenticated user's real
    // company id to become the genuine paid-tier gate. Tracked in docs/TODO.md
    // ("AI Assistant - Wire Real Company Id (Paid Tier Gate)").
    private Guid? AiTestCompanyId =>
        Guid.TryParse(Configuration["AiService:TestCompanyId"], out var id) && id != Guid.Empty
            ? id
            : null;
}