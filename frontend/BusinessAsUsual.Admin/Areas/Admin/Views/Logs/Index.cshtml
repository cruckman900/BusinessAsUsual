@{
    ViewData["Title"] = "Logs";
}

<h2>Logs</h2>

<div class="log">

    <div class="card mb-3" style="background: var(--gradient-card)">
        <div class="card-body d-flex gap-3 align-items-end">
            <div>
                <label class="form-label">Level</label>
                <select id="log-level" class="form-select">
                    <option value="">All</option>
                    <option>DEBUG</option>
                    <option>INFO</option>
                    <option>WARN</option>
                    <option>ERROR</option>
                    <option>FATAL</option>
                </select>
            </div>

            <div>
                <label class="form-label">Search</label>
                <input id="log-search" class="form-control" placeholder="Search logs..." />
            </div>

            <div>
                <label class="form-label">From</label>
                <input type="date" id="log-start" class="form-control" />
            </div>

            <div>
                <label class="form-label">To</label>
                <input type="date" id="log-end" class="form-control" />
            </div>

            <div>
                <label class="form-label">Auto Refresh</label>
                <input type="checkbox" id="log-auto" class="form-check-input ms-2" />
            </div>

            <button id="log-refresh" class="btn btn-primary ms-auto">Refresh</button>
            <button id="log-download" class="btn btn-success">Download</button>
        </div>
    </div>

    <div class="d-flex gap-3 mb-3 p-3">
        <label>Page Size</label>
        <select id="log-page-size" class="form-select" style="width: 100px;">
            <option>50</option>
            <option>100</option>
            <option selected>200</option>
            <option>500</option>
        </select>

        <button id="log-prev" class="btn btn-secondary">Prev</button>
        <button id="log-next" class="btn btn-secondary">Next</button>

        <span id="log-page-info" class="mx-3"></span>
    </div>

    <div id="log-container" class="log-window"></div>
</div>

<style>
    .log {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .log-window {
        background: #111;
        color: #eee;
        padding: 1rem;
        border-radius: 8px;
        overflow-y: auto;
        font-family: Consolas, monospace;
        font-size: 0.9rem;
        white-space: pre-wrap;
    }

    .log-entry {
        cursor: pointer;
        padding: 0.25rem 0;
        border-bottom: 1px solid #333;
    }

    .log-entry .ts { color: #888; }
    .log-entry .lvl-debug { color: #6ee7b7; }
    .log-entry .lvl-info { color: #93c5fd; }
    .log-entry .lvl-warn { color: #facc15; }
    .log-entry .lvl-error { color: #f87171; }
    .log-entry .lvl-fatal { color: #fb4141; }

    .exception-block {
        display: none;
        background: #222;
        color: #f88;
        padding: 0.5rem;
        margin: 0;
        border-left: 3px solid #f44;
        white-space: pre-wrap;
        overflow-wrap: break-word;
        tab-size: 4;
        font-size: 0.85rem;
    }

    .log-entry.expanded .exception-block {
        display: block;
    }
</style>

@section Scripts {
    <script>
        let currentPage = 1;
        let mode = "local";
        let nextToken = null;
        let prevToken = null;
        let tokenStack = []; // For minimal backward support in CloudWatch mode

        async function loadLogs() {
            const level = document.getElementById("log-level").value;
            const search = document.getElementById("log-search").value;
            const start = document.getElementById("log-start").value;
            const end = document.getElementById("log-end").value;
            const pageSize = parseInt(document.getElementById("log-page-size").value);

            const params = new URLSearchParams({
                level: level,
                search: search,
                start: start,
                end: end,
                limit: pageSize,
                page: currentPage,
                nextToken: nextToken ?? "",
                prevToken: prevToken ?? ""
            });

            const url = `/Admin/logs/data?${params.toString()}`;
            const result = await fetch(url).then(res => res.json());

            mode = result.mode;
            currentPage = result.page;
            nextToken = result.nextToken;
            prevToken = result.prevToken;

            renderLogs(result.logs);

            const pageInfo = document.getElementById("log-page-info");
            if (mode === "local") {
                pageInfo.textContent = `Page ${currentPage}`;
            } else {
                pageInfo.textContent = `CloudWatch${nextToken ? " (more available)" : ""}`;
            }

            // Enable/disable buttons based on mode
            const prevBtn = document.getElementById("log-prev");
            const nextBtn = document.getElementById("log-next");

            if (mode === "local") {
                prevBtn.disabled = currentPage <= 1;
                nextBtn.disabled = result.logs.length < pageSize;
            } else {
                prevBtn.disabled = !prevToken; // minimal backward support
                nextBtn.disabled = !nextToken;
            }
        }

        function wirePaging() {
            const prevBtn = document.getElementById("log-prev");
            const nextBtn = document.getElementById("log-next");
            const pageSizeSelect = document.getElementById("log-page-size");

            prevBtn.onclick = () => {
                if (mode === "local") {
                    if (currentPage > 1) {
                        currentPage--;
                        loadLogs();
                    }
                } else {
                    if (prevToken) {
                        // For real backward CloudWatch, you'd maintain a client-side stack.
                        nextToken = prevToken;
                        tokenStack.pop(); // discard current
                        nextToken = tokenStack[tokenStack.length - 1]; // go back
                       loadLogs();
                    }
                }
            };

            nextBtn.onclick = () => {
                if (mode === "local") {
                    currentPage++;
                    loadLogs();
                } else {
                    if (nextToken) {
                        // Move forward using CloudWatch token
                        tokenStack.push(nextToken); // Push current token before going back
                        loadLogs();
                    }
                }
            };

            pageSizeSelect.onchange = () => {
                currentPage = 1;
                tokenStack = [];
                nextToken = null;
                prevToken = null;
                loadLogs();
            };
        }

        async function renderLogs(logs) {
            const container = document.getElementById("log-container");

            container.innerHTML = logs.map(l => {
                const exception = l.exception?.trim();
                return `<div class="log-entry" onclick="this.classList.toggle('expanded')"><div class="log-line"><span class="ts">[${l.timestamp}]</span> <span class="lvl-${l.level.toLowerCase()}">   [${l.level}]</span> <span class="message">${l.message}</span></div>${exception ? `<pre class="exception-block">${exception}</pre>` : ""}</div>`.trim();
            }).join("");

            container.scrollTop = container.scrollHeight;
        }

        document.getElementById("log-refresh").onclick = () => {
            currentPage = 1;
            tokenStack = [];
            nextToken = null;
            prevToken = null;
            loadLogs();
        };
        document.getElementById("log-search").oninput = () => {
            currentPage = 1;
            tokenStack = [];
            nextToken = null;
            prevToken = null;
            loadLogs();
        };
        document.getElementById("log-level").onchange = () => {
            currentPage = 1;
            tokenStack = [];
            nextToken = null;
            prevToken = null;
            loadLogs();
        };
        document.getElementById("log-download").onclick = () => {
            const level = document.getElementById("log-level").value;
            const search = document.getElementById("log-search").value;
            const start = document.getElementById("log-start").value;
            const end = document.getElementById("log-end").value;

            const params = new URLSearchParams({
                level: level,
                search: search,
                start: start,
                end: end
            });

            window.location.href = `/admin/logs/download?${params.toString()}`;
        };

        // setInterval(() => {
        //     if (document.getElementById("log-auto").checked) loadLogs();
        // }, 3000);

        let logInterval = null;

        function applySettingsToLogs(settings) {
            if (logInterval) clearInterval(logInterval);

            if (settings.autoRefreshLogs) {
                logInterval = setInterval(loadLogs, 5000);
            }
        }

        window.addEventListener("settingsLoaded", e => {
            applySettingsToLogs(e.detail);
        });

        wirePaging();
        loadLogs();
    </script>
}