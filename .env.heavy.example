# =============================================================================
# HEAVY INSTANCE environment file  (copy to ".env" on the t3.small instance)
# -----------------------------------------------------------------------------
#   cp .env.heavy.example .env      # then fill in the real values
#   docker compose -f docker-compose.heavy.yml up -d --build
#
# Do NOT commit the real .env - it holds database credentials.
# =============================================================================

# ASP.NET Core environment (Production is recommended on the instances)
ASPNETCORE_ENVIRONMENT=Production

# --- Shared RDS (MS SQL) --------------------------------------------------
# Same RDS instance is shared by all three EC2 boxes. Use the RDS endpoint,
# not localhost. Example:
# Server=bau-db.abc123.us-east-1.rds.amazonaws.com,1433;Database=BusinessAsUsual;User Id=admin;Password=CHANGE_ME;Encrypt=True;TrustServerCertificate=True;
AWS_SQL_CONNECTION_STRING=
HR_SQL_CONNECTION_STRING=

# Set to false to make HR.Web use the shared RDS instead of its in-memory DB
HR_WEB_USE_INMEMORY=true

# --- Cross-instance service URLs -----------------------------------------
# HR.API registers with the Module Registry, which runs on the LIGHT instance.
# Use that instance's PRIVATE IP or private DNS (keep traffic inside the VPC).
# Example: http://10.0.2.15:5100
MODULE_REGISTRY_URL=http://LIGHT_INSTANCE_PRIVATE_IP:5100
