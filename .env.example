# ============================
# Business As Usual - ENV File
# Phase 1: Docker Database
# ============================

# ----------------------------
# API Configuration
# ----------------------------
API_PORT=5000
API_URL=http://localhost:5000

# ----------------------------
# Frontend Configuration
# ----------------------------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5000

# ----------------------------
# Docker Database (Phase 1)
# ----------------------------
DB_HOST=db
DB_PORT=5432
DB_USER=bau_user
DB_PASSWORD=bau_password
DB_NAME=business_as_usual

# ----------------------------
# JWT / Auth
# ----------------------------
JWT_SECRET=supersecretjwtkey
JWT_EXPIRES_IN=1d

# ----------------------------
# Node Environment
# ----------------------------
NODE_ENV=production

# ----------------------------
# Event Bus - Self-hosted RabbitMQ (docker-compose.eventbus.yml)
# Local / fallback broker only. NEVER commit real values in .env.
# ----------------------------
RABBITMQ_USER=bau
RABBITMQ_PASSWORD=change-me-locally

# ----------------------------
# Event Bus - Amazon MQ for RabbitMQ (docker-compose.eventbus.prod.yml)
# Production broker over TLS (amqps / 5671). Source these from AWS
# Secrets Manager / SSM at deploy time, not from a committed file.
# MQ_HOST = broker endpoint WITHOUT scheme/port, e.g.
#   b-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.mq.us-east-1.amazonaws.com
# ----------------------------
MQ_HOST=
MQ_USERNAME=
MQ_PASSWORD=
MQ_VHOST=/
MQ_RETRY_LIMIT=5